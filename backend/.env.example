# Copy this file to .env and fill in your values
# cp .env.example .env

# Server
PORT=3001

# ── Local dev ─────────────────────────────────────────────────────────────
# FRONTEND_URL=http://192.168.100.13:3000
# LAN_HOST=192.168.100.13

# ── Production (Render / Railway / VPS) ───────────────────────────────────
NODE_ENV=production
FRONTEND_URL=https://your-frontend.vercel.app
# Comma-separated extra origins (Capacitor, staging, etc.)
CORS_ORIGINS=capacitor://localhost,https://your-frontend.vercel.app
# Optional — shown in startup logs
# API_PUBLIC_URL=https://your-api.onrender.com

# JWT — Generate your own with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# NEVER commit the real .env file. Use this template only.
# REQUIRED in production — the server refuses to start without a strong, non-default secret.
JWT_SECRET=REPLACE_WITH_64_CHAR_HEX_FROM_COMMAND_ABOVE
JWT_EXPIRES_IN=7d

# ── Admin bootstrap account ───────────────────────────────────────────────
# The initial admin is seeded on first startup. Override BOTH in production.
# If ADMIN_PASSWORD is left at the default, the server logs a security warning.
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=REPLACE_WITH_A_STRONG_ADMIN_PASSWORD

# SQLite database path (relative to backend/)
DB_PATH=./data/directory.db

# Set to 'production' on live server
# NODE_ENV=development

# Set to 'memory' only for offline dev without Supabase
STORAGE_MODE=supabase

# ── Supabase ──────────────────────────────────────────────────────────────
# Project URL  (do NOT add /rest/v1/ — the SDK appends that automatically)
SUPABASE_URL=https://your-project-ref.supabase.co

# Anon / Public key — safe to use in the browser / frontend
# Dashboard → Project Settings → API → "anon public"
SUPABASE_ANON_KEY=your-anon-key-here

# Service Role key — server-side ONLY, bypasses Row Level Security
# Dashboard → Project Settings → API → "service_role secret"
# NEVER expose this to the frontend or commit it to git
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional — auto-apply SQL migrations on server startup (Dashboard → Settings → Database)
# SUPABASE_DB_PASSWORD=your-database-password
# Or full connection string:
# SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.[project-ref].supabase.co:5432/postgres

# ── Payments table (run backend/migrations/004_payments.sql in Supabase) ───
# Membership renewals are recorded in membership_payments and activate listings server-side.

# ── Email OTP (verify + forgot password) → Gmail via Brevo SMTP ───────────
# Codes are emailed only. Do NOT set EXPOSE_VERIFY_CODE in production.
# SUPPORT_EMAIL=yammtech80@gmail.com
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-brevo-smtp-login
SMTP_PASS=your-brevo-smtp-key
SMTP_FROM="YammTech <yammtech80@gmail.com>"
# EXPOSE_VERIFY_CODE=true   # QA only — shows code in API/app (never for real users)

# ── Firebase Cloud Messaging (real push notifications) ─────────────────────
# 1. Firebase Console → create project → add Android app (package: com.example.shiabusinessdirectory)
# 2. Download google-services.json → place in android/app/google-services.json (native APK build)
# 3. Project Settings → Service accounts → Generate new private key (JSON)
# 4. Paste that JSON as ONE LINE into FIREBASE_SERVICE_ACCOUNT_JSON (Render env),
#    OR set the three fields below.
# Without these, in-app notifications still work; phone tray push is skipped.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN...","client_email":"..."}
# FIREBASE_PROJECT_ID=your-firebase-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-...@....iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
